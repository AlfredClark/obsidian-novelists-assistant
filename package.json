{
  "name": "obsidian-novelists-assistant",
  "version": "0.1.0",
  "description": "An Obsidian Plugin to Help Chinese Novelists Create Better Works",
  "homepage": "https://github.com/AlfredClark/obsidian-novelists-assistant",
  "author": {
    "name": "Alfred Clark",
    "email": "alfredclark@163.com",
    "url": "https://github.com/AlfredClark"
  },
  "license": "GPL-3.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit --skipLibCheck && vite build --mode production",
    "lint": "eslint .",
    "check": "prettier --check '**/*.ts'",
    "format": "prettier --write '**/*.ts'",
    "dist-link": "node dist-link.ts",
    "clean": "rimraf dist main.js main.js.map",
    "clean:dist": "rimraf dist/*",
    "clean:deep": "rimraf dist main.js main.js.map node_modules",
    "version": "node version-bump.ts && git add manifest.json versions.json",
    "i18n:compile": "paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/paraglide",
    "machine-translate": "inlang machine translate --project src/i18n/project.inlang"
  },
  "dependencies": {
    "nzh": "^1.0.14",
    "obsidian": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/cli": "^3.1.15",
    "@inlang/paraglide-js": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "rimraf": "^6.1.3",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-eslint2": "^5.3.0"
  }
}
